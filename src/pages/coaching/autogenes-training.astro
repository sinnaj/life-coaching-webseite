---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import HeroSection from "../../components/HeroSection.astro";
import ContactForm from "../../components/ContactForm.astro";

const title = "Autogenes Training | Schnell zur Ruhe kommen";
const description = "Autogenes Training für innere Ruhe und Balance. Mit einfachen Formeln und mentalen Bildern zu mehr Entspannung.";
---

<Layout {title} {description}>
  <Header currentPage="coaching" />

  <main class="page-content">
    <HeroSection
      title="Autogenes Training"
      subtitle="Ruhe finden, Balance stärken"
      description="Schnell zur Ruhe kommen mit einfachen Formeln und mentalen Bildern. Mit Übungen für zuhause."
      ctaText="Termin anfragen"
      ctaHref="/kontakt"
      bgColor="dark"
    />

    <section class="section container mx-auto">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-h2 font-bold mb-spacing-lg">Was ist Autogenes Training?</h2>
        
        <p class="text-body text-text-secondary mb-spacing-lg">
          Autogenes Training ist eine wissenschaftlich anerkannte Entspannungstechnik. Mit einfachen bewussten Formeln und Konzentration lenken Sie Ihren Körper in einen Zustand von Ruhe und Entspannung.
        </p>

        <p class="text-body text-text-secondary mb-spacing-lg">
          Der große Vorteil: Es dauert nur wenige Minuten und Sie können es überall anwenden – zuhause, im Büro, unterwegs.
        </p>

        <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">Was Sie erreichen können:</h3>
        <div class="space-y-spacing-md bg-primary-light p-spacing-lg rounded-lg">
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue font-bold">✓</span>
            <p class="text-body">Schnell entspannen – auch in stressigen Momenten</p>
          </div>
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue font-bold">✓</span>
            <p class="text-body">Innere Ruhe und mentale Klarheit</p>
          </div>
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue font-bold">✓</span>
            <p class="text-body">Besseren Umgang mit Angst und Nervosität</p>
          </div>
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue font-bold">✓</span>
            <p class="text-body">Bessere Konzentration und Fokus</p>
          </div>
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue font-bold">✓</span>
            <p class="text-body">Verbesserten Schlaf</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-alt container mx-auto">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-h2 font-bold mb-spacing-lg">Das Programm</h2>
        
        <p class="text-body text-text-secondary mb-spacing-lg">
          In 4 Sitzungen lernen Sie Schritt für Schritt die Grundformeln und mentalen Bilder des Autogenen Trainings.
        </p>

        <div class="space-y-spacing-lg mb-spacing-lg">
          <div class="bg-white p-spacing-lg rounded-lg border-l-4 border-accent-blue">
            <h3 class="text-h5 font-bold text-primary-dark mb-spacing-md">Sitzung 1-2: Grundlagen</h3>
            <p class="text-body text-text-secondary">
              Sie lernen die Grundsätze und die erste Technik – Schwere und Wärme. Wir üben gemeinsam.
            </p>
          </div>

          <div class="bg-white p-spacing-lg rounded-lg border-l-4 border-accent-blue">
            <h3 class="text-h5 font-bold text-primary-dark mb-spacing-md">Sitzung 3-4: Vertiefung &amp; Üben</h3>
            <p class="text-body text-text-secondary">
              Weitere Techniken und Vertiefung. Sie erhalten MP3-Aufnahmen zum Üben zuhause.
            </p>
          </div>
        </div>

        <div class="bg-accent-blue text-white p-spacing-lg rounded-lg mb-spacing-lg">
          <p class="text-h5 font-bold mb-spacing-md">Ihre Investition</p>
          <p class="text-h2 font-bold mb-spacing-md">280 €</p>
          <p class="">4 Sitzungen à 45 Minuten + MP3-Dateien zum Üben</p>
        </div>

        <p class="text-body text-text-secondary bg-primary-light p-spacing-lg rounded-lg">
          Nach dem Programm haben Sie eine Fähigkeit, die Ihr ganzes Leben bereichert – die Fähigkeit, schnell zu entspannen, wann immer Sie es brauchen.
        </p>
      </div>
    </section>

    <section class="section container mx-auto">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-h2 font-bold mb-spacing-lg text-center">Bereit, innere Ruhe zu entdecken?</h2>
        <p class="text-center text-body text-text-secondary mb-spacing-xl">
          Vereinbaren Sie ein kostenfreies Erstgespräch.
        </p>
        <ContactForm />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
