---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import HeroSection from "../../components/HeroSection.astro";
import ContactForm from "../../components/ContactForm.astro";

const title = "Raucherentwöhnung Online mit Hypnose | 3er Intensiv-Programm";
const description = "Rauchfrei mit Hypnose und Mental-Coaching. 3-Sitzungen-Intensivprogramm mit bewährten Methoden. Jetzt Termin vereinbaren.";
const toBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, "")}`;
};
---

<Layout {title} {description}>
  <Header currentPage="coaching" />

  <main class="page-content">
    <!-- Hero Section -->
    <HeroSection
      title="Raucherentwöhnung – Endlich aufatmen"
      subtitle="Rauchfrei mit Hypnose"
      description="Ein speziell entwickeltes 3-Sitzungen-Programm, um dich einfühlsam und professionell auf deinem Weg in ein rauchfreies Leben zu begleiten."
      ctaText="Termin anfragen"
      ctaHref="/kontakt"
      bgColor="dark"
      image={toBase("/images/rauchfrei-beach.jpg")}
    />

    <!-- Why This Program Works -->
    <section class="section container mx-auto">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-h2 font-bold mb-spacing-lg">Warum dieser Ansatz funktioniert</h2>
        
        <p class="text-body text-text-secondary mb-spacing-lg">
          Rauchen ist oft mehr als Gewohnheit – es ist eine Bewältigung von Stress, innerer Unruhe oder Langeweile. Deshalb arbeiten wir nicht nur an der Gewohnheit selbst, sondern auch an den inneren Strukturen dahinter.
        </p>

        <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">Mein Programm kombiniert bewährte Methoden:</h3>
        <div class="space-y-spacing-md bg-primary-light p-spacing-lg rounded-lg mb-spacing-lg">
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue font-bold">●</span>
            <div>
              <p class="font-semibold text-primary-dark">Kognitive Verhaltenstherapie</p>
              <p class="text-body text-text-secondary">Verstehen und Verändern von Mustern</p>
            </div>
          </div>
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue font-bold">●</span>
            <div>
              <p class="font-semibold text-primary-dark">Mental-Coaching</p>
              <p class="text-body text-text-secondary">Ressourcen stärken, neue Gewohnheiten aufbauen</p>
            </div>
          </div>
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue font-bold">●</span>
            <div>
              <p class="font-semibold text-primary-dark">Hypnose nach Milton Erickson</p>
              <p class="text-body text-text-secondary">Innere Blockaden lösen, positive Vision verankern</p>
            </div>
          </div>
        </div>

        <p class="text-body text-text-secondary">
          <strong>Ein Plus:</strong> Als Sozialtherapeutin mit Schwerpunkt Sucht und ehemalige Raucherin kenne ich beide Seiten dieses Weges.
        </p>
      </div>
    </section>

    <!-- Program Structure -->
    <section class="section section-alt container mx-auto">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-h2 font-bold mb-spacing-lg">So ist das Programm aufgebaut</h2>
        
        <div class="space-y-spacing-lg">
          <div class="bg-white p-spacing-lg rounded-lg border-l-4 border-accent-blue">
            <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">
              Sitzung 1: Analyse & Erstes Coaching (150 Minuten)
            </h3>
            <p class="text-body text-text-secondary">
              Eingehende Analyse Ihres Rauchverhaltens. Wir schauen gemeinsam, welche Situationen, Gefühle oder Gedanken zum Rauchen führen. Erste Hypnose zur Lösung innerer Blockaden.
            </p>
          </div>

          <div class="bg-white p-spacing-lg rounded-lg border-l-4 border-accent-blue">
            <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">
              Sitzung 2: Rauchstopp-Vorbereitung (120 Minuten)
            </h3>
            <p class="text-body text-text-secondary">
              Der eigentliche Rauchstopp wird intensiv vorbereitet. Durch Mental-Coaching und Hypnose stärkst du deine Ressourcen, entwickelst neue Verhaltensweisen und verankerst eine positive Vision deines rauchfreien Lebens.
            </p>
          </div>

          <div class="bg-white p-spacing-lg rounded-lg border-l-4 border-accent-blue">
            <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">
              Sitzung 3: Stabilisierung & positive Zukunftsvision (60 Minuten)
            </h3>
            <p class="text-body text-text-secondary">
              Wir sprechen über erste Erfahrungen, stärken deine Zuversicht und entwickeln eine positive Zukunftsvision für dein rauchfreies Leben.
            </p>
          </div>
        </div>

        <p class="text-body text-text-secondary bg-accent-light p-spacing-lg rounded-lg mt-spacing-lg">
          <strong>Gesamt:</strong> 5,5 Stunden Coaching, flexibel in 2-4 Wochen machbar
        </p>
      </div>
    </section>

    <!-- What You Can Expect -->
    <section class="section container mx-auto">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-h2 font-bold mb-spacing-lg">Was du erreichen kannst</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-spacing-md mb-spacing-lg">
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue text-h3 font-bold">✓</span>
            <p class="text-body">Verständnis für dein Rauchverhalten und deine Auslöser</p>
          </div>
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue text-h3 font-bold">✓</span>
            <p class="text-body">Sicherheit und Vertrauen für den Rauchstopp</p>
          </div>
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue text-h3 font-bold">✓</span>
            <p class="text-body">Konkrete Strategien für schwierige Momente</p>
          </div>
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue text-h3 font-bold">✓</span>
            <p class="text-body">Neue, gesunde Gewohnheiten</p>
          </div>
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue text-h3 font-bold">✓</span>
            <p class="text-body">Innere Stabilität und Ressourcenkraft</p>
          </div>
          <div class="flex gap-spacing-md items-start">
            <span class="text-accent-blue text-h3 font-bold">✓</span>
            <p class="text-body">Nachhaltige Rauchfreiheit</p>
          </div>
        </div>

        <p class="text-body text-text-secondary bg-primary-light p-spacing-lg rounded-lg">
          Dieser Ansatz wird dich dabei unterstützen, wirklich mit dem Rauchen aufzuhören, nicht nur für einen Moment, sondern nachhaltig.
        </p>
      </div>
    </section>

    <!-- Practical Information -->
    <section class="section section-alt container mx-auto">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-h2 font-bold mb-spacing-lg">Organisatorisches</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-spacing-lg mb-spacing-lg">
          <div class="bg-white p-spacing-lg rounded-lg border-t-4 border-accent-blue">
            <p class="text-h5 font-bold text-primary-dark mb-spacing-md">Format</p>
            <p class="text-body">Online via Zoom</p>
          </div>
          <div class="bg-white p-spacing-lg rounded-lg border-t-4 border-accent-blue">
            <p class="text-h5 font-bold text-primary-dark mb-spacing-md">Dauer gesamt</p>
            <p class="text-body">5,5 Stunden (3 Sitzungen)</p>
          </div>
          <div class="bg-white p-spacing-lg rounded-lg border-t-4 border-accent-blue">
            <p class="text-h5 font-bold text-primary-dark mb-spacing-md">Zeitrahmen</p>
            <p class="text-body">2-4 Wochen, flexibel</p>
          </div>
          <div class="bg-white p-spacing-lg rounded-lg border-t-4 border-accent-blue">
            <p class="text-h5 font-bold text-primary-dark mb-spacing-md">Preis</p>
            <p class="text-body">550 €</p>
          </div>
          <div class="bg-white p-spacing-lg rounded-lg border-t-4 border-accent-blue">
            <p class="text-h5 font-bold text-primary-dark mb-spacing-md">Material</p>
            <p class="text-body">Begleitunterlagen & Hypnose-Aufnahmen</p>
          </div>
          <div class="bg-white p-spacing-lg rounded-lg border-t-4 border-accent-blue">
            <p class="text-h5 font-bold text-primary-dark mb-spacing-md">Ausrüstung</p>
            <p class="text-body">Laptop, Tablet oder Smartphone</p>
          </div>
        </div>

        <p class="text-body text-text-secondary bg-accent-light p-spacing-lg rounded-lg">
          Alles, was du brauchst, ist ein ruhiger Ort und ein internetfähiges Gerät.
        </p>
      </div>
    </section>

    <!-- Scientific Backing -->
    <section class="section container mx-auto">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-h2 font-bold mb-spacing-lg">Wissenschaftlich fundiert</h2>
        
        <p class="text-body text-text-secondary mb-spacing-lg">
          Das Programm orientiert sich am anerkannten Rauchfrei-Programm des IFT (Institut für Therapieforschung) und basiert auf bewährter Verhaltenstherapie und modernen Hypnose-Methoden.
        </p>

        <p class="text-body text-text-secondary">
          Ich bin Sozialtherapeutin mit Schwerpunkt Sucht und habe langjährige Erfahrung in der Begleitung von Menschen mit Suchtthemen.
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section section-alt container mx-auto">
      <h2 class="text-h2 font-bold mb-spacing-xl">Häufig gestellte Fragen</h2>
      
      <div class="max-w-3xl space-y-spacing-lg">
        <div class="bg-white p-spacing-lg rounded-lg">
          <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">
            Funktioniert das wirklich?
          </h3>
          <p class="text-body text-text-secondary">
            Diese Kombination aus Verhaltenstherapie, Mental-Coaching und Hypnose hat bei vielen Menschen sehr gut funktioniert. Die Erfolgschancen sind hoch, wenn du bereit bist, aktiv mitzumachen.
          </p>
        </div>

        <div class="bg-white p-spacing-lg rounded-lg">
          <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">
            Was ist, wenn ich rückfällig werde?
          </h3>
          <p class="text-body text-text-secondary">
            Das passiert vielen, es ist kein Versagen, sondern Teil des Prozesses. Darum haben wir die 3. Sitzung. Und du hast die Aufnahmen und Strategien zum Weitermachen.
          </p>
        </div>

        <div class="bg-white p-spacing-lg rounded-lg">
          <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">
            Ist Hypnose sicher?
          </h3>
          <p class="text-body text-text-secondary">
            Ja, vollkommen sicher. Hypnose nach Milton Erickson ist eine ruhige, entspannende Erfahrung. Du schläfst nicht und hast vollständige Kontrolle.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section container mx-auto">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-h2 font-bold mb-spacing-lg text-center">
          Rauchfrei starten – Termin vereinbaren
        </h2>
        <p class="text-center text-body text-text-secondary mb-spacing-xl">
          Vereinbare ein Erstgespräch.
        </p>
        <ContactForm />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
