---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroSection from "../components/HeroSection.astro";
import ContactForm from "../components/ContactForm.astro";

const title = "Kontakt | Christiane Meik Coaching";
const description = "Kontaktieren Sie mich für ein kostenfreies Erstgespräch. Per Formular, E-Mail oder Telefon – ich freue mich, von Ihnen zu hören.";
---

<Layout {title} {description}>
  <Header currentPage="kontakt" />

  <main class="page-content">
    <!-- Hero Section -->
    <HeroSection
      title="Kontakt"
      subtitle="Lassen Sie uns gemeinsam schauen"
      description="Nutzen Sie das Kontaktformular oder kontaktieren Sie mich direkt per E-Mail oder Telefon. Ich freue mich, von Ihnen zu hören."
      bgColor="dark"
    />

    <!-- Contact Form Section -->
    <section class="section container mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-spacing-2xl">
        <!-- Form Column -->
        <div class="lg:col-span-2">
          <h2 class="text-h2 font-bold mb-spacing-lg">Kontaktformular</h2>
          <p class="text-body text-text-secondary mb-spacing-lg">
            Füllen Sie gerne das Formular aus. Ich antworte Ihnen normalerweise innerhalb von 24 Stunden.
          </p>
          <ContactForm />
        </div>

        <!-- Contact Info Column -->
        <div class="bg-primary-light p-spacing-lg rounded-lg h-fit">
          <h2 class="text-h3 font-bold text-primary-dark mb-spacing-lg">Direkter Kontakt</h2>
          
          <div class="space-y-spacing-lg">
            <div>
              <h3 class="text-h5 font-semibold text-primary-dark mb-spacing-md">Email</h3>
              <a
                href="mailto:kontakt@christiane-meik-coaching.de"
                class="text-accent-blue hover:text-accent-blue-dark font-semibold transition-colors break-all"
              >
                kontakt@christiane-meik-coaching.de
              </a>
            </div>

            <div>
              <h3 class="text-h5 font-semibold text-primary-dark mb-spacing-md">Telefon</h3>
              <a
                href="tel:+49123456789"
                class="text-accent-blue hover:text-accent-blue-dark font-semibold transition-colors"
              >
                +49 (0) 123 456789
              </a>
            </div>

            <div>
              <h3 class="text-h5 font-semibold text-primary-dark mb-spacing-md">Erreichbarkeit</h3>
              <p class="text-body text-text-secondary">
                Montag – Freitag: 9:00 – 18:00 Uhr<br />
                Samstag nach Vereinbarung
              </p>
            </div>

            <div class="border-t border-primary-light pt-spacing-lg mt-spacing-lg">
              <h3 class="text-h5 font-semibold text-primary-dark mb-spacing-md">Hinweis</h3>
              <p class="text-sm text-text-secondary">
                Dies ist ein Online-Coaching-Angebot. Alle Sitzungen finden via Zoom statt.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="section section-alt container mx-auto">
      <h2 class="text-h2 font-bold mb-spacing-xl">Häufig gestellte Fragen</h2>
      
      <div class="max-w-3xl space-y-spacing-lg">
        <div class="bg-white p-spacing-lg rounded-lg">
          <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">
            Wie schnell bekomme ich eine Antwort?
          </h3>
          <p class="text-body text-text-secondary">
            Ich bemühe mich, innerhalb von 24 Stunden zu antworten. Bei zeitsensibler Anfrage können Sie mich auch anrufen.
          </p>
        </div>

        <div class="bg-white p-spacing-lg rounded-lg">
          <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">
            Wann kann ich starten?
          </h3>
          <p class="text-body text-text-secondary">
            Das hängt von Ihrem und meinem Kalender ab. Meist können wir innerhalb von 1-2 Wochen einen Termin für ein Erstgespräch vereinbaren. Urgent-Anfragen versuche ich schneller zu bearbeiten.
          </p>
        </div>

        <div class="bg-white p-spacing-lg rounded-lg">
          <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">
            Ist das Erstgespräch wirklich kostenlos?
          </h3>
          <p class="text-body text-text-secondary">
            Ja, vollkommen kostenlos. Im Erstgespräch klären wir, ob die Passung stimmt, welches Angebot zu Ihnen passt, und Sie können offene Fragen stellen.
          </p>
        </div>

        <div class="bg-white p-spacing-lg rounded-lg">
          <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">
            Kann ich Fragen stellen, bevor ich mich anmelde?
          </h3>
          <p class="text-body text-text-secondary">
            Natürlich! Schreiben Sie mir gerne eine E-Mail oder rufen Sie an. Ich beantworte gerne Ihre Fragen zum Coaching.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
