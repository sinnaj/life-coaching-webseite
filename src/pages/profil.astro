---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroSection from "../components/HeroSection.astro";

const title = "Über mich | Christiane Meik";
const description = "Lerne meine Geschichte, meine Qualifikationen und meinen Ansatz zum Life Coaching kennen.";
const toBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, "")}`;
};
---

<Layout {title} {description}>
  <Header currentPage="profil" />

  <main class="page-content">
    <!-- Hero Section -->
    <HeroSection
      title="Mein Profil"
      subtitle="Wer ich bin und warum ich coache"
      description="Ich bin Diplom-Pädagogin und zertifizierte Trainerin mit langjähriger therapeutischer Erfahrung."
      bgColor="dark"
    />

    <!-- Main Content -->
    <section class="section container mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-spacing-2xl items-start">
        <!-- Image Placeholder -->
        <div class="lg:col-span-1">
          <div class="bg-primary-light rounded-lg p-spacing-xl flex items-center justify-center aspect-square">
            <div class="text-center text-text-secondary">
              <p class="text-h4 font-semibold">Foto</p>
              <p class="text-sm">Porträt wird hinzugefügt</p>
            </div>
          </div>
        </div>

        <!-- Content -->
        <div class="lg:col-span-2">
          <h2 class="text-h2 font-bold mb-spacing-lg">Wer ich bin</h2>

          <p class="text-body text-text-secondary mb-spacing-lg">
            Ich bin Diplom-Pädagogin und zertifizierte Trainerin mit langjähriger therapeutischer Erfahrung. Als ausgebildete Suchttherapeutin und Mental-Coach verbinde ich wissenschaftliche Erkenntnisse mit alltagstauglichen Strategien.
          </p>

          <p class="text-body text-text-secondary mb-spacing-lg">
            Von 2003 bis 2025 habe ich in meiner eigenen Privatpraxis als Heilpraktikerin für Psychotherapie gearbeitet. Ab 2026 fokussiere ich mich auf psychologisch fundiertes Mental-Coaching für Stressbewältigung, Entspannung, Raucherentwöhnung und kontrolliertes Trinken.
          </p>

          <h3 class="text-h3 font-bold text-primary-dark mb-spacing-lg mt-spacing-xl">Qualifikationen</h3>

          <div class="space-y-spacing-md">
            <div class="flex gap-spacing-md items-start bg-primary-light p-spacing-md rounded">
              <span class="text-accent-blue font-bold text-h4">✓</span>
              <div>
                <p class="font-semibold text-primary-dark">Diplom-Pädagogin</p>
                <p class="text-sm text-text-secondary">Universität, 1998</p>
              </div>
            </div>

            <div class="flex gap-spacing-md items-start bg-primary-light p-spacing-md rounded">
              <span class="text-accent-blue font-bold text-h4">✓</span>
              <div>
                <p class="font-semibold text-primary-dark">Heilpraktikerin für Psychotherapie</p>
                <p class="text-sm text-text-secondary">Erworben 2003</p>
              </div>
            </div>

            <div class="flex gap-spacing-md items-start bg-primary-light p-spacing-md rounded">
              <span class="text-accent-blue font-bold text-h4">✓</span>
              <div>
                <p class="font-semibold text-primary-dark">Ausgebildete Suchttherapeutin</p>
                <p class="text-sm text-text-secondary">Fachspezialiserung, 2005</p>
              </div>
            </div>

            <div class="flex gap-spacing-md items-start bg-primary-light p-spacing-md rounded">
              <span class="text-accent-blue font-bold text-h4">✓</span>
              <div>
                <p class="font-semibold text-primary-dark">Mental-Coach</p>
                <p class="text-sm text-text-secondary">Zertifizierung, 2015</p>
              </div>
            </div>

            <div class="flex gap-spacing-md items-start bg-primary-light p-spacing-md rounded">
              <span class="text-accent-blue font-bold text-h4">✓</span>
              <div>
                <p class="font-semibold text-primary-dark">Hypnose-Therapeutin (Milton Erickson)</p>
                <p class="text-sm text-text-secondary">Weiterbildung, 2018</p>
              </div>
            </div>
          </div>

          <h3 class="text-h3 font-bold text-primary-dark mb-spacing-lg mt-spacing-xl">Mein Weg</h3>

          <p class="text-body text-text-secondary">
            Über mehr als 20 Jahre habe ich tausenden von Menschen in schwierigen Lebenssituationen begleitet. Diese umfangreiche Erfahrung hat mich gelehrt, Menschen in ihrer Vielfalt wahrzunehmen, zu verstehen und professionell zu unterstützen.
          </p>
        </div>
      </div>
    </section>

    <!-- Values Section -->
    <section class="section section-alt container mx-auto">
      <h2 class="text-h2 font-bold mb-spacing-xl text-center">Meine Werte im Coaching</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-spacing-lg max-w-4xl mx-auto">
        <div class="bg-white p-spacing-lg rounded-lg border-t-4 border-accent-blue">
          <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">Empathie</h3>
          <p class="text-body text-text-secondary">
            Ich höre wirklich zu und verstehe Ihre Situation aus echtem Interesse heraus.
          </p>
        </div>

        <div class="bg-white p-spacing-lg rounded-lg border-t-4 border-accent-blue">
          <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">Fachkompetenz</h3>
          <p class="text-body text-text-secondary">
            Mein Wissen beruht auf wissenschaftlichen Erkenntnissen und jahrelanger praktischer Erfahrung.
          </p>
        </div>

        <div class="bg-white p-spacing-lg rounded-lg border-t-4 border-accent-blue">
          <h3 class="text-h4 font-bold text-primary-dark mb-spacing-md">Verlässlichkeit</h3>
          <p class="text-body text-text-secondary">
            Sie können sich auf meine Zusagen verlassen. Diskretion ist selbstverständlich.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section container mx-auto">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-h2 font-bold mb-spacing-lg">Lassen Sie uns zusammenarbeiten</h2>
        <p class="text-body text-text-secondary mb-spacing-lg">
          Im kostenfreien Erstgespräch können Sie mich kennenlernen und wir schauen gemeinsam, wie ich Sie am besten unterstützen kann.
        </p>
        <a
          href={toBase("/kontakt")}
          class="inline-block px-spacing-lg py-spacing-md bg-accent-blue text-white font-semibold rounded hover:bg-accent-blue-dark transition-colors"
        >
          Termin vereinbaren
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
