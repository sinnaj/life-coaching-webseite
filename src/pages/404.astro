---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Wartungsarbeiten"
  description="Die Website wird gerade aktualisiert. In Kürze sind wir wieder für Sie da."
  noindex={true}
>
  <main class="min-h-screen flex items-center justify-center px-md py-3xl">
    <div class="max-w-xl w-full bg-card-bg rounded-2xl shadow-md p-2xl text-center">
      <p class="text-tiny uppercase tracking-widest text-text-tertiary mb-md">
        Christiane Meik Coaching
      </p>
      <h1 class="text-h2-mobile md:text-h1 text-text-primary mb-lg">
        Die Seite wird gerade aktualisiert.
      </h1>
      <p class="text-body text-text-secondary mb-lg">
        Wir nehmen kurz redaktionelle Anpassungen vor und sind in Kürze wieder
        für Sie erreichbar. Vielen Dank für Ihr Verständnis.
      </p>
      <div class="border-t border-accent-gray pt-lg mt-lg text-small text-text-tertiary">
        <p class="mb-sm">Sie erreichen mich in dringenden Fällen direkt:</p>
        <p>
          <a class="text-accent-blue hover:text-accent-blue-dark underline" href="mailto:info@meik-gesundheit.de">
            info@meik-gesundheit.de
          </a>
        </p>
        <p class="mt-xs">
          <a class="text-accent-blue hover:text-accent-blue-dark" href="tel:+494043265481">
            +49 40 43265481
          </a>
        </p>
      </div>
    </div>
  </main>
</Layout>
