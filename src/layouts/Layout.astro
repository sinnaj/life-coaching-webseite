---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "article";
  canonical?: string;
  noindex?: boolean;
  keywords?: string[];
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = "Psychologisch fundiertes Life Coaching & Mental-Coaching Online",
  ogImage,
  ogImageAlt = "Christiane Meik Coaching - psychologisch fundiertes Online-Coaching",
  ogType = "website",
  canonical,
  noindex = false,
  keywords = [],
  schema,
} = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const faviconHref = `${base}favicon.svg`;
const siteOrigin = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageUrl = ogImage
  ? new URL(ogImage, siteOrigin).toString()
  : new URL(`${base}images/christiane-headshot-professional.jpeg`, siteOrigin).toString();
const robotsContent = noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large";
const keywordContent = keywords.join(", ");

const globalSchema: Array<Record<string, unknown>> = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Christiane Meik Coaching",
    url: new URL(base, siteOrigin).toString(),
    inLanguage: "de-DE",
    description,
    publisher: {
      "@type": "Person",
      name: "Christiane Meik",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Christiane Meik",
    jobTitle: "Mental-Coach",
    description: "Diplom-Pädagogin und Mental-Coach mit psychologisch fundiertem Online-Coaching-Angebot.",
    url: new URL(base, siteOrigin).toString(),
    image: new URL(`${base}images/christiane-headshot-professional.jpeg`, siteOrigin).toString(),
    email: "info@meik-gesundheit.de",
    telephone: "+49-40-43265481",
    knowsAbout: [
      "Life Coaching",
      "Stressbewältigung",
      "Raucherentwöhnung",
      "Autogenes Training",
      "Kontrolliertes Trinken",
      "Mental-Coaching",
    ],
  },
];

const pageSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const schemas = [...globalSchema, ...pageSchemas];
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content="Christiane Meik" />
    <meta name="description" content={description} />
    {keywordContent && <meta name="keywords" content={keywordContent} />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Christiane Meik Coaching" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {schemas.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}

    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <title>{title} | Christiane Meik Coaching</title>
  </head>
  <body class="bg-page-bg">
    <slot />
  </body>
</html>
