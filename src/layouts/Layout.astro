---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "Psychologisch fundiertes Life Coaching & Mental-Coaching Online", ogImage } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const faviconHref = `${base}favicon.svg`;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <title>{title} | Christiane Meik Coaching</title>
  </head>
  <body class="bg-page-bg">
    <slot />
  </body>
</html>
