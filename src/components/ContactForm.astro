---
// Tally embed for the contact form. Form data is stored in the EU (Tally BV / Belgium).
// Email notifications are delivered via SendGrid (DPF-certified).
const formId = "yP7bbd";
const embedSrc = `https://tally.so/embed/${formId}?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1`;
const fallbackHref = `https://tally.so/r/${formId}`;
const toBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, "")}`;
};
---

<div class="max-w-2xl">
  <iframe
    data-tally-src={embedSrc}
    src={embedSrc}
    loading="lazy"
    width="100%"
    height="600"
    frameborder="0"
    marginheight="0"
    marginwidth="0"
    title="Kontaktformular"
    class="w-full border-0"
  ></iframe>

  <noscript>
    <p class="mt-spacing-md text-sm text-text-secondary">
      Falls das Formular nicht geladen wird, öffnen Sie es bitte
      <a href={fallbackHref} class="text-accent-blue hover:underline" target="_blank" rel="noopener noreferrer">direkt bei Tally</a>
      oder schreiben Sie mir an
      <a href="mailto:info@meik-gesundheit.de" class="text-accent-blue hover:underline">info@meik-gesundheit.de</a>.
    </p>
  </noscript>

  <p class="mt-spacing-md text-xs text-text-tertiary">
    Mit dem Absenden des Formulars akzeptieren Sie die
    <a href={toBase("/datenschutz")} class="text-accent-blue hover:underline">Datenschutzerklärung</a>.
  </p>
</div>

<script is:inline src="https://tally.so/widgets/embed.js"></script>
<script is:inline>
  if (typeof window !== "undefined" && typeof window.Tally !== "undefined") {
    window.Tally.loadEmbeds();
  }
</script>
